---
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Pagination from '~/components/blog/Pagination.astro';

import { blogListRobots, getStaticPathsBlogList, findTags, findStacks, findTypes, fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

export async function getStaticPaths ({ paginate }) {
  return await getStaticPathsBlogList({ paginate });
}

const { page } = Astro.props;
const currentPage = page.currentPage ?? 1;

const allPosts = await fetchPosts();
const allTags = await findTags();
const allStacks = await findStacks();
const allTypes = await findTypes();
const featured = allPosts.filter((post) => post.featured).slice(0, 8);

const typeLabels: Record<string, string> = {
  service: 'Servicio',
  tool: 'Herramienta',
  library: 'Libreria',
  repository: 'Repositorio',
  framework: 'Framework',
  template: 'Template',
  integration: 'Integracion',
  'github-action': 'GitHub Action',
  'desktop-app': 'App desktop',
  'ai-tool': 'IA',
  'component-library': 'Componentes',
  'package-registry': 'Paquetes',
};

const metadata = {
  title: `Directorio de recursos${currentPage > 1 ? ` — Pagina ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'website',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 py-16 sm:py-24 lg:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <p class="mb-4 text-caption uppercase tracking-[0.2em] font-medium" style="color: var(--color-mute);">
            Directorio de recursos para desarrolladores
          </p>
          <h1 class="text-display-xl max-w-3xl" style="color: var(--color-ink);">
            Encuentra lo que necesitas.
          </h1>
          <p class="mt-6 text-body-lg max-w-xl" style="color: var(--color-body);">
            Herramientas, repositorios, librerias y servicios organizados por tipo, tecnologia y caso de uso. Para que no pierdas tiempo buscando.
          </p>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div class="rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <div class="text-display-sm" style="color: var(--color-ink);">{allPosts.length}</div>
            <div class="mt-1 text-caption uppercase tracking-widest" style="color: var(--color-mute);">recursos</div>
          </div>
          <div class="rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <div class="text-display-sm" style="color: var(--color-ink);">{allTags.length}</div>
            <div class="mt-1 text-caption uppercase tracking-widest" style="color: var(--color-mute);">tags</div>
          </div>
          <div class="rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <div class="text-display-sm" style="color: var(--color-ink);">{allStacks.length}</div>
            <div class="mt-1 text-caption uppercase tracking-widest" style="color: var(--color-mute);">stacks</div>
          </div>
        </div>
      </div>

      <div class="mt-12 rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
        <div class="grid gap-4 lg:grid-cols-[1fr_180px_180px_180px]">
          <label class="relative block">
            <span class="sr-only">Buscar recursos</span>
            <input
              data-resource-search
              class="w-full rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
              style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
              type="search"
              placeholder="Buscar: enviar emails, monitorizar, tailwind, API..."
            />
          </label>
          <select
            data-resource-type
            class="rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
            style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
          >
            <option value="">Todos los tipos</option>
            {allTypes.map(({ type, count }) => <option value={type}>{typeLabels[type] || type.replaceAll('-', ' ')} ({count})</option>)}
          </select>
          <select
            data-resource-stack
            class="rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
            style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
          >
            <option value="">Todos los stacks</option>
            {allStacks.map(({ stack, count }) => <option value={stack}>{stack} ({count})</option>)}
          </select>
          <select
            data-resource-sort
            class="rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
            style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
          >
            <option value="default">Ordenar: por defecto</option>
            <option value="alpha-asc">Nombre A → Z</option>
            <option value="alpha-desc">Nombre Z → A</option>
            <option value="date-desc">Mas recientes</option>
            <option value="date-asc">Mas antiguos</option>
            <option value="featured">Destacados primero</option>
          </select>
        </div>
        <div class="mt-4 flex flex-wrap gap-2" data-tag-filter-list>
          {allTags.slice(0, 20).map(({ tag, count }) => (
            <button
              type="button"
              data-resource-tag={tag}
              class="rounded-sm px-3 py-1.5 text-caption font-medium transition"
              style="background-color: var(--color-canvas); color: var(--color-body); border: 1px solid var(--color-hairline);"
            >
              {tag} <span style="color: var(--color-mute);">{count}</span>
            </button>
          ))}
        </div>
      </div>

      {featured.length > 0 && (
        <div class="mt-12">
          <h2 class="text-display-sm mb-4" style="color: var(--color-ink);">Destacados</h2>
          <div class="flex gap-3 overflow-x-auto pb-2">
            {featured.map((post) => (
              <a
                href={getPermalink(post.permalink, 'post')}
                class="min-w-[240px] rounded-md p-4 transition hover:opacity-80"
                style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);"
              >
                <span class="block text-caption uppercase tracking-widest" style="color: var(--color-mute);">{typeLabels[post.type] || post.type?.replaceAll('-', ' ')}</span>
                <span class="mt-1 block text-body-md-strong" style="color: var(--color-ink);">{post.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="px-6 pb-16 sm:pb-24 lg:pb-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-8 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <p class="text-caption uppercase tracking-[0.2em] font-medium" style="color: var(--color-mute);">Explorar</p>
          <h2 class="mt-2 text-display-md" style="color: var(--color-ink);">Todos los recursos</h2>
        </div>
        <div class="flex items-center gap-4">
          <p class="text-body-sm" style="color: var(--color-mute);"><span data-result-count>{page.data.length}</span> recursos</p>
          <div class="flex gap-1 rounded-sm p-1" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <button
              data-view-toggle="grid"
              aria-label="Vista en cuadricula"
              class="rounded-xs px-2 py-1 transition"
              style="background-color: var(--color-canvas); color: var(--color-ink);"
              title="Vista cuadricula"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            </button>
            <button
              data-view-toggle="list"
              aria-label="Vista en lista"
              class="rounded-xs px-2 py-1 transition"
              style="color: var(--color-mute);"
              title="Vista lista"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </button>
          </div>
        </div>
      </div>
      <BlogList posts={page.data} />
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </section>

  <script>
    const searchInput = document.querySelector<HTMLInputElement>('[data-resource-search]');
    const typeSelect = document.querySelector<HTMLSelectElement>('[data-resource-type]');
    const stackSelect = document.querySelector<HTMLSelectElement>('[data-resource-stack]');
    const sortSelect = document.querySelector<HTMLSelectElement>('[data-resource-sort]');
    const tagButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-resource-tag]'));
    const resourceList = document.querySelector<HTMLUListElement>('[data-resource-list]');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-resource-card]'));
    const emptyState = document.querySelector<HTMLElement>('[data-empty-state]');
    const resultCount = document.querySelector<HTMLElement>('[data-result-count]');
    const viewToggles = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view-toggle]'));
    let activeTag = '';

    // ── URL params ─────────────────────────────────────────────────────────────
    function getParams() {
      const p = new URLSearchParams(window.location.search);
      return {
        q: p.get('q') || '',
        type: p.get('type') || '',
        stack: p.get('stack') || '',
        tag: p.get('tag') || '',
        sort: p.get('sort') || '',
      };
    }

    function pushParams() {
      const p = new URLSearchParams();
      const q = searchInput?.value?.trim() || '';
      const type = typeSelect?.value || '';
      const stack = stackSelect?.value || '';
      const sort = sortSelect?.value && sortSelect.value !== 'default' ? sortSelect.value : '';
      if (q) p.set('q', q);
      if (type) p.set('type', type);
      if (stack) p.set('stack', stack);
      if (activeTag) p.set('tag', activeTag);
      if (sort) p.set('sort', sort);
      const search = p.toString();
      history.replaceState(null, '', search ? `?${search}` : window.location.pathname);
    }

    function restoreFromParams() {
      const { q, type, stack, tag, sort } = getParams();
      if (searchInput && q) searchInput.value = q;
      if (typeSelect && type) typeSelect.value = type;
      if (stackSelect && stack) stackSelect.value = stack;
      if (sortSelect && sort) sortSelect.value = sort;
      if (tag) {
        activeTag = tag;
        tagButtons.forEach((btn) => {
          if (btn.dataset.resourceTag === tag) {
            btn.style.backgroundColor = 'var(--color-primary)';
            btn.style.color = 'var(--color-on-primary)';
            btn.style.borderColor = 'var(--color-primary)';
          }
        });
      }
    }

    // ── Sorting ─────────────────────────────────────────────────────────────────
    function getSortedItems(items: HTMLElement[]) {
      const sort = sortSelect?.value || 'default';
      if (sort === 'default') return items;
      const arr = [...items];
      switch (sort) {
        case 'alpha-asc':
          return arr.sort((a, b) => (a.dataset.title || '').localeCompare(b.dataset.title || ''));
        case 'alpha-desc':
          return arr.sort((a, b) => (b.dataset.title || '').localeCompare(a.dataset.title || ''));
        case 'date-desc':
          return arr.sort((a, b) => (b.dataset.date || '').localeCompare(a.dataset.date || ''));
        case 'date-asc':
          return arr.sort((a, b) => (a.dataset.date || '').localeCompare(b.dataset.date || ''));
        case 'featured':
          return arr.sort((a, b) => {
            const af = a.dataset.featured === 'true' ? 0 : 1;
            const bf = b.dataset.featured === 'true' ? 0 : 1;
            return af - bf;
          });
        default:
          return arr;
      }
    }

    // ── Filtering + rendering ───────────────────────────────────────────────────
    const applyFilters = () => {
      const query = searchInput?.value?.toLowerCase().trim() || '';
      const type = typeSelect?.value || '';
      const stack = stackSelect?.value || '';
      let visible = 0;

      cards.forEach((card) => {
        const matchesSearch = !query || card.dataset.search?.includes(query);
        const matchesType = !type || card.dataset.type === type;
        const matchesStack = !stack || card.dataset.stack?.split(' ').includes(stack);
        const matchesTag = !activeTag || card.dataset.tags?.split(' ').includes(activeTag);
        const matches = matchesSearch && matchesType && matchesStack && matchesTag;
        card.closest('li')?.classList.toggle('hidden', !matches);
        if (matches) visible += 1;
      });

      // Apply sort by reordering DOM
      if (resourceList) {
        const visibleItems = Array.from(resourceList.querySelectorAll<HTMLElement>('li:not(.hidden)'));
        const visibleCards = visibleItems.map((li) => li.querySelector<HTMLElement>('[data-resource-card]')).filter(Boolean) as HTMLElement[];
        const sorted = getSortedItems(visibleCards);
        sorted.forEach((card) => {
          const li = card.closest('li');
          if (li) resourceList.appendChild(li);
        });
      }

      emptyState?.classList.toggle('hidden', visible !== 0);
      if (resultCount) resultCount.textContent = String(visible);
      pushParams();
    };

    // ── View toggle ─────────────────────────────────────────────────────────────
    function applyView(view: string) {
      if (!resourceList) return;
      if (view === 'list') {
        resourceList.classList.remove('md:grid-cols-2', 'lg:grid-cols-3');
        resourceList.classList.add('grid-cols-1');
      } else {
        resourceList.classList.remove('grid-cols-1');
        resourceList.classList.add('md:grid-cols-2', 'lg:grid-cols-3');
      }
      viewToggles.forEach((btn) => {
        const isActive = btn.dataset.viewToggle === view;
        btn.style.backgroundColor = isActive ? 'var(--color-canvas)' : 'transparent';
        btn.style.color = isActive ? 'var(--color-ink)' : 'var(--color-mute)';
      });
      localStorage.setItem('devlinks-view', view);
    }

    viewToggles.forEach((btn) => {
      btn.addEventListener('click', () => applyView(btn.dataset.viewToggle || 'grid'));
    });

    // ── Init ────────────────────────────────────────────────────────────────────
    restoreFromParams();

    const savedView = localStorage.getItem('devlinks-view') || 'grid';
    applyView(savedView);

    searchInput?.addEventListener('input', applyFilters);
    typeSelect?.addEventListener('change', applyFilters);
    stackSelect?.addEventListener('change', applyFilters);
    sortSelect?.addEventListener('change', applyFilters);

    tagButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeTag = activeTag === button.dataset.resourceTag ? '' : button.dataset.resourceTag || '';
        tagButtons.forEach((item) => {
          if (item === button && activeTag) {
            item.style.backgroundColor = 'var(--color-primary)';
            item.style.color = 'var(--color-on-primary)';
            item.style.borderColor = 'var(--color-primary)';
          } else {
            item.style.backgroundColor = 'var(--color-canvas)';
            item.style.color = 'var(--color-body)';
            item.style.borderColor = 'var(--color-hairline)';
          }
        });
        applyFilters();
      });
    });

    // Apply filters on load if URL params present
    const params = getParams();
    if (params.q || params.type || params.stack || params.tag || params.sort) {
      applyFilters();
    }
  </script>
</Layout>
