---
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Pagination from '~/components/blog/Pagination.astro';

import { blogListRobots, getStaticPathsBlogList, findTags, findStacks, findTypes, fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

export async function getStaticPaths ({ paginate }) {
  return await getStaticPathsBlogList({ paginate });
}

const { page } = Astro.props;
const currentPage = page.currentPage ?? 1;

const allPosts = await fetchPosts();
const allTags = await findTags();
const allStacks = await findStacks();
const allTypes = await findTypes();
const featured = allPosts.filter((post) => post.featured).slice(0, 8);

const metadata = {
  title: `Directorio de recursos${currentPage > 1 ? ` — Pagina ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'website',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 py-16 sm:py-24 lg:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <p class="mb-4 text-caption uppercase tracking-[0.2em] font-medium" style="color: var(--color-mute);">
            Directorio de recursos para desarrolladores
          </p>
          <h1 class="text-display-xl max-w-3xl" style="color: var(--color-ink);">
            Encuentra lo que necesitas.
          </h1>
          <p class="mt-6 text-body-lg max-w-xl" style="color: var(--color-body);">
            Herramientas, repositorios, librerias y servicios organizados por tipo, tecnologia y caso de uso. Para que no pierdas tiempo buscando.
          </p>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div class="rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <div class="text-display-sm" style="color: var(--color-ink);">{allPosts.length}</div>
            <div class="mt-1 text-caption uppercase tracking-widest" style="color: var(--color-mute);">recursos</div>
          </div>
          <div class="rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <div class="text-display-sm" style="color: var(--color-ink);">{allTags.length}</div>
            <div class="mt-1 text-caption uppercase tracking-widest" style="color: var(--color-mute);">tags</div>
          </div>
          <div class="rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
            <div class="text-display-sm" style="color: var(--color-ink);">{allStacks.length}</div>
            <div class="mt-1 text-caption uppercase tracking-widest" style="color: var(--color-mute);">stacks</div>
          </div>
        </div>
      </div>

      <div class="mt-12 rounded-md p-5" style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);">
        <div class="grid gap-4 lg:grid-cols-[1fr_200px_200px]">
          <label class="relative block">
            <span class="sr-only">Buscar recursos</span>
            <input
              data-resource-search
              class="w-full rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
              style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
              type="search"
              placeholder="Buscar: enviar emails, monitorizar, tailwind, API..."
            />
          </label>
          <select
            data-resource-type
            class="rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
            style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
          >
            <option value="">Todos los tipos</option>
            {allTypes.map(({ type, count }) => <option value={type}>{type.replaceAll('-', ' ')} ({count})</option>)}
          </select>
          <select
            data-resource-stack
            class="rounded-sm px-4 py-3 text-body-sm font-medium outline-none"
            style="background-color: var(--color-canvas); color: var(--color-ink); border: 1px solid var(--color-hairline);"
          >
            <option value="">Todos los stacks</option>
            {allStacks.map(({ stack, count }) => <option value={stack}>{stack} ({count})</option>)}
          </select>
        </div>
        <div class="mt-4 flex flex-wrap gap-2" data-tag-filter-list>
          {allTags.slice(0, 20).map(({ tag, count }) => (
            <button
              type="button"
              data-resource-tag={tag}
              class="rounded-sm px-3 py-1.5 text-caption font-medium transition"
              style="background-color: var(--color-canvas); color: var(--color-body); border: 1px solid var(--color-hairline);"
            >
              {tag} <span style="color: var(--color-mute);">{count}</span>
            </button>
          ))}
        </div>
      </div>

      {featured.length > 0 && (
        <div class="mt-12">
          <h2 class="text-display-sm mb-4" style="color: var(--color-ink);">Destacados</h2>
          <div class="flex gap-3 overflow-x-auto pb-2">
            {featured.map((post) => (
              <a
                href={getPermalink(post.permalink, 'post')}
                class="min-w-[240px] rounded-md p-4 transition hover:opacity-80"
                style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline);"
              >
                <span class="block text-caption uppercase tracking-widest" style="color: var(--color-mute);">{post.type?.replaceAll('-', ' ')}</span>
                <span class="mt-1 block text-body-md-strong" style="color: var(--color-ink);">{post.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="px-6 pb-16 sm:pb-24 lg:pb-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-8 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <p class="text-caption uppercase tracking-[0.2em] font-medium" style="color: var(--color-mute);">Explorar</p>
          <h2 class="mt-2 text-display-md" style="color: var(--color-ink);">Todos los recursos</h2>
        </div>
        <p class="text-body-sm" style="color: var(--color-mute);"><span data-result-count>{page.data.length}</span> recursos</p>
      </div>
      <BlogList posts={page.data} />
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </section>

  <script>
    const searchInput = document.querySelector('[data-resource-search]');
    const typeSelect = document.querySelector('[data-resource-type]');
    const stackSelect = document.querySelector('[data-resource-stack]');
    const tagButtons = Array.from(document.querySelectorAll('[data-resource-tag]'));
    const cards = Array.from(document.querySelectorAll('[data-resource-card]'));
    const emptyState = document.querySelector('[data-empty-state]');
    const resultCount = document.querySelector('[data-result-count]');
    let activeTag = '';

    const applyFilters = () => {
      const query = searchInput?.value?.toLowerCase().trim() || '';
      const type = typeSelect?.value || '';
      const stack = stackSelect?.value || '';
      let visible = 0;

      cards.forEach((card) => {
        const matchesSearch = !query || card.dataset.search?.includes(query);
        const matchesType = !type || card.dataset.type === type;
        const matchesStack = !stack || card.dataset.stack?.split(' ').includes(stack);
        const matchesTag = !activeTag || card.dataset.tags?.split(' ').includes(activeTag);
        const matches = matchesSearch && matchesType && matchesStack && matchesTag;

        card.closest('li')?.classList.toggle('hidden', !matches);
        if (matches) visible += 1;
      });

      emptyState?.classList.toggle('hidden', visible !== 0);
      if (resultCount) resultCount.textContent = String(visible);
    };

    searchInput?.addEventListener('input', applyFilters);
    typeSelect?.addEventListener('change', applyFilters);
    stackSelect?.addEventListener('change', applyFilters);
    tagButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeTag = activeTag === button.dataset.resourceTag ? '' : button.dataset.resourceTag || '';
        tagButtons.forEach((item) => {
          if (item === button && activeTag) {
            item.style.backgroundColor = 'var(--color-primary)';
            item.style.color = 'var(--color-on-primary)';
            item.style.borderColor = 'var(--color-primary)';
          } else {
            item.style.backgroundColor = 'var(--color-canvas)';
            item.style.color = 'var(--color-body)';
            item.style.borderColor = 'var(--color-hairline)';
          }
        });
        applyFilters();
      });
    });
  </script>
</Layout>
