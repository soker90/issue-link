---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import { fetchHistoricalPosts } from '~/utils/blog';

export const prerender = true;

const posts = await fetchHistoricalPosts();

const metadata = {
  title: 'Histórico',
  description: 'Recursos antiguos que ya no se consideran relevantes, conservados como archivo histórico.',
  robots: { index: false, follow: true },
};
---

<Layout metadata={metadata}>
  <section class="px-6 py-16 sm:py-24 lg:py-32">
    <div class="mx-auto max-w-6xl">
      <p class="mb-4 text-caption uppercase tracking-[0.2em] font-medium" style="color: var(--color-mute);">Archivo</p>
      <h1 class="text-display-xl" style="color: var(--color-ink);">Histórico</h1>
      <p class="mt-6 max-w-2xl text-body-lg" style="color: var(--color-body);">
        Recursos que en su día estuvieron en el directorio pero que ya no consideramos relevantes
        (descontinuados, reemplazados o desactualizados). Se conservan aquí como referencia.
      </p>

      <div class="mt-12">
        {
          posts.length > 0 ? (
            <>
              <p class="mb-6 text-body-sm" style="color: var(--color-mute);">{posts.length} recursos archivados</p>
              <BlogList posts={posts} />
            </>
          ) : (
            <p
              class="rounded-md p-8 text-center text-body-md font-medium"
              style="color: var(--color-mute); border: 1px dashed var(--color-hairline);"
            >
              Todavia no hay recursos en el historico.
            </p>
          )
        }
      </div>

      <a
        class="mt-10 inline-flex items-center gap-2 text-body-sm font-medium transition hover:opacity-80"
        style="color: var(--color-mute);"
        href="/"
      >
        <Icon name="tabler:arrow-left" class="h-4 w-4" /> Volver al directorio
      </a>
    </div>
  </section>
</Layout>
