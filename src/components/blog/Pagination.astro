---
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  prevUrl: string;
  nextUrl: string;
  prevText?: string;
  nextText?: string;
}

const { prevUrl, nextUrl, prevText = 'Anterior', nextText = 'Siguiente' } = Astro.props;
---

{
  (prevUrl || nextUrl) && (
    <div class="mt-8 flex justify-between">
      <a
        class:list={['inline-flex items-center gap-2 rounded-sm px-4 py-2.5 text-body-sm font-medium transition hover:opacity-80', { invisible: !prevUrl }]}
        style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline); color: var(--color-ink);"
        href={getPermalink(prevUrl)}
      >
        <Icon name="tabler:chevron-left" class="w-4 h-4" />
        {prevText}
      </a>

      <a
        class:list={['inline-flex items-center gap-2 rounded-sm px-4 py-2.5 text-body-sm font-medium transition hover:opacity-80', { invisible: !nextUrl }]}
        style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline); color: var(--color-ink);"
        href={getPermalink(nextUrl)}
      >
        {nextText}
        <Icon name="tabler:chevron-right" class="w-4 h-4" />
      </a>
    </div>
  )
}
