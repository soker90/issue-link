---
import { Icon } from 'astro-icon/components';
import PostTags from '~/components/blog/Tags.astro';

import type { Post } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { formatCompactNumber } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const internalLink = getPermalink(post.permalink, 'post');
const externalLink = post.link || post.repo || post.docs;
const search = [post.title, post.excerpt, post.useCase, post.type, ...(post.tags || []), ...(post.stack || [])]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();

const typeLabels: Record<string, string> = {
  service: 'Servicio',
  tool: 'Herramienta',
  library: 'Libreria',
  repository: 'Repositorio',
  framework: 'Framework',
  template: 'Template',
  integration: 'Integracion',
  'github-action': 'GitHub Action',
  'desktop-app': 'App desktop',
  'ai-tool': 'IA',
  'component-library': 'Componentes',
  'package-registry': 'Paquetes',
};

const typeLabel = post.type ? typeLabels[post.type] || post.type.replaceAll('-', ' ') : 'Recurso';

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const isNew = post.publishDate ? new Date(post.publishDate) > thirtyDaysAgo : false;
const publishDateStr = post.publishDate ? new Date(post.publishDate).toISOString().split('T')[0] : '';
const starsLabel = formatCompactNumber(post.stars);
const lastCommitLabel = post.lastCommit
  ? new Intl.DateTimeFormat('es', { month: 'short', year: 'numeric', timeZone: 'UTC' }).format(new Date(post.lastCommit))
  : null;

// Evitar repetir como etiqueta lo que ya se muestra en el stack
const stackSet = new Set((post.stack || []).map((s) => s.toLowerCase()));
const visibleTags = (post.tags || []).filter((tag) => !stackSet.has(tag.toLowerCase()));
---

<article
  class="group relative flex h-full flex-col rounded-md transition"
  style={`background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline); padding: 24px;${post.archived ? ' opacity: 0.6;' : ''}`}
  data-resource-card
  data-search={search}
  data-type={post.type || ''}
  data-tags={(post.tags || []).join(' ')}
  data-stack={(post.stack || []).join(' ')}
  data-title={post.title?.toLowerCase() || ''}
  data-date={publishDateStr}
  data-featured={post.featured ? 'true' : 'false'}
>
  <div class="mb-4 flex items-start justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-caption uppercase tracking-[0.18em] font-medium" style="color: var(--color-mute);">
        {typeLabel}
      </span>
      {isNew && (
        <span class="rounded-xs px-1.5 py-0.5 text-caption font-medium uppercase tracking-wider" style="background-color: var(--color-success, #36d399); color: var(--color-canvas);">
          nuevo
        </span>
      )}
      {post.archived && (
        <span class="rounded-xs px-1.5 py-0.5 text-caption font-medium uppercase tracking-wider" style="background-color: var(--color-warning, #c2410c); color: #fff;">
          archivado
        </span>
      )}
    </div>
    <div class="flex shrink-0 items-center gap-3">
      {starsLabel && (
        <span class="flex items-center gap-1 text-caption font-medium" style="color: var(--color-mute);" title={`${post.stars} estrellas en GitHub`}>
          <Icon name="tabler:star" class="h-3.5 w-3.5" /> {starsLabel}
        </span>
      )}
      {lastCommitLabel && (
        <span class="flex items-center gap-1 text-caption font-medium" style="color: var(--color-mute);" title="Último commit">
          <Icon name="tabler:git-commit" class="h-3.5 w-3.5" /> {lastCommitLabel}
        </span>
      )}
      {post.featured && <Icon name="tabler:sparkles" class="h-4 w-4 shrink-0" style="color: var(--color-primary);" />}
    </div>
  </div>

  <h2 class="mb-3 text-display-sm" style="color: var(--color-ink);">
    <a class="transition hover:opacity-80" href={internalLink}>{post.title}</a>
  </h2>

  {post.useCase && <p class="mb-4 text-body-sm font-medium" style="color: var(--color-body-strong);">{post.useCase}</p>}
  {post.excerpt && <p class="mb-5 flex-grow text-body-sm" style="color: var(--color-body);">{post.excerpt}</p>}

  {post.stack?.length ? (
    <div class="mb-4 flex flex-wrap gap-2">
      {post.stack.slice(0, 4).map((item) => (
        <span class="rounded-xs px-2 py-1 text-caption font-medium" style="background-color: var(--color-canvas); color: var(--color-body);">{item}</span>
      ))}
    </div>
  ) : null}

  <PostTags tags={visibleTags.slice(0, 5)} class="mb-5 text-caption" />

  <div class="mt-auto flex flex-wrap items-center gap-3" style="border-top: 1px solid var(--color-hairline); padding-top: 16px;">
    {externalLink && (
      <a
        class="btn-primary rounded-sm text-caption font-medium"
        href={externalLink}
        target="_blank"
        rel="noopener noreferrer"
      >
        Abrir <Icon name="tabler:external-link" class="h-3.5 w-3.5 ml-1" />
      </a>
    )}
    <a class="text-caption font-medium transition hover:opacity-80" style="color: var(--color-mute);" href={internalLink}>
      Ver ficha <Icon name="tabler:arrow-right" class="h-3.5 w-3.5 inline" />
    </a>
  </div>
</article>
