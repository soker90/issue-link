---
import Item from '~/components/blog/ListItem.astro';
import type { Post } from '~/types';

export interface Props {
  posts: Array<Post>;
}

const { posts } = Astro.props;
---

<ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3" data-resource-list>
  {
    posts.map((post) => (
      <li>
        <Item post={post} />
      </li>
    ))
  }
</ul>
<p class="hidden rounded-md p-8 text-center text-body-md font-medium" style="color: var(--color-mute); border: 1px dashed var(--color-hairline);" data-empty-state>
  No hay recursos que encajen con esos filtros.
</p>
