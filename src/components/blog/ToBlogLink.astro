---
import { Icon } from 'astro-icon/components';
import { getHomePermalink } from '~/utils/permalinks';
---

<div class="mx-auto px-6 max-w-5xl pt-8 pb-12 md:pb-20">
  <a
    class="inline-flex items-center gap-2 rounded-sm px-4 py-2.5 text-body-sm font-medium transition hover:opacity-80"
    style="background-color: var(--color-canvas-soft); border: 1px solid var(--color-hairline); color: var(--color-ink);"
    href={getHomePermalink()}
  >
    <Icon name="tabler:chevron-left" class="w-4 h-4" /> Volver al directorio
  </a>
</div>
